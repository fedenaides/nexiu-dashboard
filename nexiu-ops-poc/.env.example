# Copia este archivo a `.env` (sin .example) y rellená los valores reales.
# .env está en .gitignore — nunca lo subas al repo.

# === Google Sheets warehouse ===
SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pegá ACÁ TODO el contenido del JSON de la service account (con saltos de línea \n escapados).
# Si te resulta más cómodo en local, podés usar SERVICE_ACCOUNT_JSON_PATH apuntando al archivo.
GOOGLE_SERVICE_ACCOUNT_JSON=
SERVICE_ACCOUNT_JSON_PATH=/ruta/local/etl-service-account.json

# === META Marketing API ===
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_1234567890123456

# === Google Ads (DESACTIVADO hasta aprobación de Basic Access) ===
# Cuando te aprueben, pegá los valores acá y descomentá la sección.
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_CUSTOMER_IDS=

# === Configuración ETL ===
# Cuántos días hacia atrás trae cada corrida (default: 7)
ETL_LOOKBACK_DAYS=7
